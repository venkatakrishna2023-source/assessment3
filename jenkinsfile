pipeline {
    agent any

    tools {
        
        maven 'Maven' 
    }

    stages {
        stage('Checkout') {
            steps {
                
                checkout scm
            }
        }

        stage('Build') {
            steps {
                
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Test') {
            steps {
                
                sh 'mvn test'
            }
            post {
                always {
                    junit 'target/surefire-reports/*.xml'
                }
            }
        }
    }
}
